---
import { salon } from '@/data/salon';
---

<section id="uslugi" class="section-y bg-surface/60" aria-labelledby="uslugi-tytul">
  <div class="container-px">
    <div class="max-w-3xl">
      <span class="label">Usługi</span>
      <h2
        id="uslugi-tytul"
        class="mt-3 text-display-sm sm:text-display-md font-display font-medium"
      >
        Pełen zakres pielęgnacji w jednym miejscu.
      </h2>
      <p class="mt-4 text-body-md text-ink-secondary">
        Od kąpieli po profesjonalne strzyżenie — dobieramy zabieg do indywidualnych potrzeb Twojego
        pupila.
      </p>
    </div>

    <ul role="list" class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        salon.services.map((service, idx) => (
          <li class="card flex flex-col">
            <span class="label">{String(idx + 1).padStart(2, '0')}</span>
            <h3 class="mt-3 font-display text-xl font-semibold text-ink-primary">
              {service.title}
            </h3>
            <p class="mt-2 text-body-sm text-ink-secondary">{service.description}</p>
            <a
              href="#rezerwacja"
              class="mt-4 inline-flex items-center gap-1 font-mono text-label-md uppercase tracking-wider text-primary-dark hover:underline"
            >
              Umów wizytę
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
