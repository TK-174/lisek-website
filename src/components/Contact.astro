---
import { salon } from '@/data/salon';

const mapsQuery = encodeURIComponent(salon.address);
const mapsEmbed = `https://www.google.com/maps?q=${mapsQuery}&output=embed`;
---

<section id="kontakt" class="section-y bg-surface/60" aria-labelledby="kontakt-tytul">
  <div class="container-px">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-5">
        <span class="label">Kontakt</span>
        <h2
          id="kontakt-tytul"
          class="mt-3 text-display-sm sm:text-display-md font-display font-medium"
        >
          Skontaktuj się z nami.
        </h2>
        <p class="mt-4 text-body-md text-ink-secondary">
          Najlepiej zadzwoń lub napisz — odpowiadamy w ciągu jednego dnia roboczego.
        </p>

        <dl class="mt-8 space-y-5">
          <div>
            <dt class="label">Adres</dt>
            <dd class="mt-1 font-display text-base">{salon.address}</dd>
          </div>
          <div>
            <dt class="label">Telefon</dt>
            <dd class="mt-1 font-display text-base">
              <a class="hover:underline" href={`tel:${salon.phoneHref}`}>{salon.phone}</a>
            </dd>
          </div>
          <div>
            <dt class="label">E-mail</dt>
            <dd class="mt-1 font-display text-base">
              <a class="hover:underline" href={`mailto:${salon.email}`}>{salon.email}</a>
            </dd>
          </div>
          <div>
            <dt class="label">Godziny otwarcia</dt>
            <dd class="mt-1 space-y-1">
              {
                salon.hours.map((h) => (
                  <p class="font-display text-base">
                    <span class="text-ink-primary">{h.days}</span>
                    <span class="mx-2 text-ink-secondary">·</span>
                    <span class="text-ink-secondary">{h.hours}</span>
                  </p>
                ))
              }
            </dd>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-7">
        <div class="overflow-hidden rounded-card border border-line bg-surface shadow-card">
          <iframe
            src={mapsEmbed}
            title={`Mapa: ${salon.name}, ${salon.address}`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="block h-[420px] w-full border-0"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
